function handleDataUpload(ev){
  const file=ev.target.files[0];if(!file)return;
  const okExt=/\.(xlsx|xls|csv)$/i.test(file.name);
  const MAX_BYTES=25*1024*1024; // 25MB cap to avoid memory-exhaustion / DoS from a malicious file
  if(!okExt){toast('⚠️ Unsupported file type — please upload .xlsx, .xls, or .csv','error');ev.target.value='';return;}
  if(file.size>MAX_BYTES){toast('⚠️ File too large (max 25MB)','error');ev.target.value='';return;}
  if(typeof XLSX==='undefined'){toast('⚠️ Excel library not loaded — check your connection','error');return;}
  toast('⏳ Reading '+file.name+'…','info');
  const reader=new FileReader();
  reader.onload=e=>{
    try{
      const wb=XLSX.read(new Uint8Array(e.target.result),{type:'array',cellDates:true});
      const updated=processWorkbook(wb);
      if(!updated.length){toast('⚠️ No recognizable sheets found. Need "Fleet master data", "Control Tower" or "Dispatch Report" sheets.','error');return;}
      refreshAll();
      toast('✅ Loaded: '+updated.join(' · ')+' from '+file.name,'success');
    }catch(err){console.error(err);toast('❌ Could not read file: '+err.message,'error');}
  };
  reader.onerror=()=>toast('❌ Failed to read file','error');
  reader.readAsArrayBuffer(file);
  ev.target.value='';
}
// Locates a header row in an array-of-arrays sheet dump by a regex match against any cell,
// then returns {hdrIdx, col(name)->index lookup}.
function findHeader(aoa,testRe){
  const hdrIdx=aoa.findIndex(r=>r&&r.some(c=>testRe.test(String(c))));
  if(hdrIdx<0)return null;
  const hdr=aoa[hdrIdx];
  return {hdrIdx,col:name=>hdr.findIndex(h=>h!==null&&h!==undefined&&new RegExp(name,'i').test(String(h)))};
}
function processWorkbook(wb){
  const updated=[];
  // 1) Fleet master data — also pulls the (unlabeled) assignment column right after "Remark" for ownership
  const fleetSheet=wb.SheetNames.find(n=>/fleet|master/i.test(n));
  if(fleetSheet){
    const aoa=XLSX.utils.sheet_to_json(wb.Sheets[fleetSheet],{header:1,defval:null});
    const h=findHeader(aoa,/REG PLATE/i);
    if(h){
      const plateI=h.col('REG PLATE'),modelI=h.col('^MODEL$'),typeI=h.col('FLEET TYPE'),brandI=h.col('FLEET BRAND'),
        driverI=h.col('Driver Name'),bizI=h.col('^Business$'),regionI=h.col('^Region$'),palletI=h.col('Pallet Capacity'),
        statusI=h.col('Operational status'),mvpiI=h.col('^MVPI$'),remarkI=h.col('^Remark$');
      const assignI=remarkI>=0?remarkI+1:-1;
      const nf=[];
      for(let i=h.hdrIdx+1;i<aoa.length;i++){
        const r=aoa[i];if(!r)continue;
        const plate=plateI>=0?r[plateI]:null;
        if(!plate||!String(plate).trim())continue;
        const mvpiVal=mvpiI>=0?r[mvpiI]:null;
        let mv=null;
        if(mvpiVal instanceof Date)mv=mvpiVal.toISOString().slice(0,10);
        else if(mvpiVal&&/[0-9]{2,}/.test(String(mvpiVal)))mv=String(mvpiVal);
        const status=String(statusI>=0?(r[statusI]||'Active'):'Active');
        const assign=String(assignI>=0?(r[assignI]||''):'').toLowerCase();
        const bizVal=String(bizI>=0?(r[bizI]||'—'):'—').replace('#N/A','—');
        const own=(assign.includes('dedicated')||bizVal.toLowerCase().includes('dedicated'))?'Dedicated':'Owned';
        nf.push({no:nf.length+1,plate:String(plate),yr:modelI>=0&&r[modelI]?Number(r[modelI]):null,
          type:String(typeI>=0?(r[typeI]||''):''),brand:String(brandI>=0?(r[brandI]||''):'').split('-')[0].trim(),
          driver:String(driverI>=0?(r[driverI]||'—'):'—').replace('#N/A','—').trim(),
          biz:bizVal,region:normRegion(regionI>=0?r[regionI]:''),
          pallets:palletI>=0?(Number(r[palletI])||0):0,status,active:status.startsWith('Active'),
          mvpi:mv,own});
      }
      if(nf.length){FLEET_DATA.length=0;nf.forEach(f=>FLEET_DATA.push(f));rebuildFleetIndex();updated.push(nf.length+' vehicles');}
    }
  }
  // 2) Control Tower hub data — read BOTH OTM and TMS dashboard sheets
  const parseDash=(sheetName,sys)=>{
    const aoa=XLSX.utils.sheet_to_json(wb.Sheets[sheetName],{header:1,defval:null});
    const hdrIdx=aoa.findIndex(r=>r&&r.some(c=>/Warehouse Hub|Org Code/i.test(String(c))));
    if(hdrIdx<0)return [];
    const nh=[],seen=new Set();
    for(let i=hdrIdx+1;i<aoa.length;i++){
      const r=aoa[i];if(!r)continue;
      const c0=String(r[0]||'').trim();
      if(/grand total/i.test(c0))break;
      if(!c0||seen.has(c0))continue;
      const tamer=+r[1]||0,out=+r[2]||0,tot=+r[3]||(tamer+out);if(!tot)continue;
      seen.add(c0);
      const cleanShort=c0.replace(/_WAREHOUSE/i,'').replace(/^[0-9]+[-_\s]*/,'').replace(/_/g,' ').trim();
      nh.push({hub:c0,short:cleanShort||c0,system:sys,
        region:/RYD|RIYADH|324|328/i.test(c0)?'RIYADH':/JED|220|221|223/i.test(c0)?'JEDDAH':/KHB|KHOBAR|524|526/i.test(c0)?'KHOBAR':/ABHA|420/i.test(c0)?'ABHA':/BUR|342/i.test(c0)?'BURAIDAH':/MAD|242/i.test(c0)?'MADINAH':'OTHER',
        tamer,outsource:out,total:tot,tamer_pct:+(tamer/tot*100).toFixed(1),outsource_pct:+(out/tot*100).toFixed(1)});
    }
    return nh;
  };
  const otmSheet=wb.SheetNames.find(n=>/control.*otm|dashboard.*otm|otm/i.test(n)&&/control|dashboard|tower/i.test(n));
  const tmsSheet=wb.SheetNames.find(n=>/control.*tms|dashboard.*tms|tms/i.test(n)&&/control|dashboard|tower/i.test(n));
  const genericSheet=wb.SheetNames.find(n=>/control|tower|dashboard/i.test(n)&&!/otm|tms/i.test(n));
  let allHubs=[];
  if(otmSheet)allHubs=allHubs.concat(parseDash(otmSheet,'OTM'));
  if(tmsSheet)allHubs=allHubs.concat(parseDash(tmsSheet,'TMS'));
  if(!otmSheet&&!tmsSheet&&genericSheet)allHubs=allHubs.concat(parseDash(genericSheet,'OTM'));
  if(allHubs.length){
    HUBS_ALL.length=0;allHubs.forEach(h=>HUBS_ALL.push(h));
    REGIONS_ALL.length=0;
    ['OTM','TMS'].forEach(sys=>{
      const sh=allHubs.filter(h=>h.system===sys);if(!sh.length)return;
      const rg={};sh.forEach(h=>{if(!rg[h.region])rg[h.region]={region:h.region,system:sys,tamer:0,outsource:0,total:0};rg[h.region].tamer+=h.tamer;rg[h.region].outsource+=h.outsource;rg[h.region].total+=h.total;});
      Object.values(rg).forEach(r=>REGIONS_ALL.push({...r,tamer_pct:+(r.tamer/r.total*100).toFixed(1),outsource_pct:+(r.outsource/r.total*100).toFixed(1)}));
    });
    ['OTM','TMS'].forEach(sys=>{
      const sh=allHubs.filter(h=>h.system===sys);if(!sh.length)return;
      const t=sh.reduce((s,h)=>s+h.total,0),tm=sh.reduce((s,h)=>s+h.tamer,0);
      TOTALS_BY_SYS[sys]={trips:t,tamer:tm,outsource:t-tm,tamer_pct:+(tm/t*100).toFixed(2),avg_pallets:TOTALS_BY_SYS[sys]?.avg_pallets||2};
    });
    const systems=[...new Set(allHubs.map(h=>h.system))];
    updated.push(allHubs.length+' hubs ('+systems.join('+')+')');
  }
  // 3) Dispatch Report OTM/TMS — rebuild the trip-level TRIPS dataset behind Operations Detail
  const newTrips=parseDispatchTrips(wb);
  if(newTrips.length){TRIPS.length=0;newTrips.forEach(t=>TRIPS.push(t));updated.push(newTrips.length+' trips (dispatch detail)');}
  return updated;
}
// Aggregates raw OTM/TMS dispatch-report rows into one record per trip (Shipment/Manifest ID),
// matching the same logic used to build the dashboard's initial embedded TRIPS dataset:
// truck ownership = outsource flag + Fleet Master assignment match; drop = distinct end-customer/destination;
// POD status = Delivered if every line has a POD date, Returned if any line shows a return/refusal, else Pending.
function parseDispatchTrips(wb){
  const out=[];
  const otmName=wb.SheetNames.find(n=>/dispatch.*otm/i.test(n));
  if(otmName){
    const aoa=XLSX.utils.sheet_to_json(wb.Sheets[otmName],{header:1,defval:null});
    const h=findHeader(aoa,/Shipment\/?Manifest ID/i);
    if(h){
      const cShip=h.col('Shipment\\/?Manifest ID'),cStart=h.col('^Ship Start$'),cSrc=h.col('Source Location ID'),
        cRegion=h.col('^Region$'),cAcct=h.col('OBD Corporation'),cTruck=h.col('Truck Nbr'),cType=h.col('^Truck Type$'),
        cFleet=h.col('Actual Fleet Type'),cPallets=h.col('Ballets Loading'),cCases=h.col('Case Dispatched'),
        cCust=h.col('End Customer ID'),cPOD=h.col('^POD$'),cRound=h.col('Round Type'),cRefusal=h.col('Refusal Reason'),cPartial=h.col('Partial Return');
      const groups={};
      for(let i=h.hdrIdx+1;i<aoa.length;i++){
        const r=aoa[i];if(!r)continue;
        const ship=cShip>=0?r[cShip]:null;if(!ship)continue;
        const key=String(ship);
        if(!groups[key])groups[key]={dates:[],wh:cSrc>=0?r[cSrc]:null,region:cRegion>=0?String(r[cRegion]||'').toUpperCase():'',accts:{},trucks:{},types:{},pallets:0,cases:0,orders:0,custs:new Set(),allDeliv:true,anyReturn:false,outsource:false};
        const g=groups[key];
        const sd=cStart>=0?r[cStart]:null;
        if(sd){const dt=(sd instanceof Date)?sd:new Date(sd);if(!isNaN(dt))g.dates.push(dt.toISOString().slice(0,10));}
        const acct=cAcct>=0?r[cAcct]:null;if(acct)g.accts[acct]=(g.accts[acct]||0)+1;
        const truck=cTruck>=0?r[cTruck]:null;if(truck)g.trucks[truck]=(g.trucks[truck]||0)+1;
        const ty=cType>=0?r[cType]:null;if(ty)g.types[ty]=(g.types[ty]||0)+1;
        g.pallets+=Number(cPallets>=0?r[cPallets]:0)||0;
        g.cases+=Number(cCases>=0?r[cCases]:0)||0;
        g.orders+=1;
        const cust=cCust>=0?r[cCust]:null;if(cust)g.custs.add(String(cust));
        const flag=cFleet>=0?r[cFleet]:null;
        if(flag&&String(flag).toUpperCase().includes('OUTSOURCE'))g.outsource=true;
        if(!(cPOD>=0&&r[cPOD]))g.allDeliv=false;
        const rt=String(cRound>=0?(r[cRound]||''):'');
        if(/return/i.test(rt)||(cRefusal>=0&&r[cRefusal])||(cPartial>=0&&r[cPartial]))g.anyReturn=true;
      }
      Object.values(groups).forEach(g=>{
        const truckPlate=Object.entries(g.trucks).sort((a,b)=>b[1]-a[1])[0]?.[0]||'—';
        const ttype=Object.entries(g.types).sort((a,b)=>b[1]-a[1])[0]?.[0]||'UNKNOWN';
        const acct=Object.entries(g.accts).sort((a,b)=>b[1]-a[1])[0]?.[0]||'Unspecified';
        let own;
        if(g.outsource)own='T';
        else{const f=PLATE_OWN[normPlate(truckPlate)];own=f?(f==='Dedicated'?'D':'O'):'U';}
        const pod=g.allDeliv?'D':(g.anyReturn?'R':'P');
        out.push([g.dates.sort()[0]||'',String(g.wh||'UNKNOWN'),g.region||'UNKNOWN',String(acct),String(truckPlate),String(ttype),own,+g.pallets.toFixed(1),Math.round(g.cases),g.orders,g.custs.size||1,pod,'O']);
      });
    }
  }
  const tmsName=wb.SheetNames.find(n=>/dispatch.*tms/i.test(n));
  if(tmsName){
    const aoa=XLSX.utils.sheet_to_json(wb.Sheets[tmsName],{header:1,defval:null});
    const h=findHeader(aoa,/^Shipment_ID$/i);
    if(h){
      const cShip=h.col('^Shipment_ID$'),cDate=h.col('Dispatched_Date'),cSrc=h.col('Source_Location'),
        cRegion=h.col('^Region$'),cAcct=h.col('Buisness|Business'),cTruck=h.col('Truck_Number'),cType=h.col('Truck_Type'),
        cFleet=h.col('Actual Fleet Type'),cPallets=h.col('^Pallets$'),cCases=h.col('^Cases$'),cDest=h.col('Destination_ID');
      const groups={};
      for(let i=h.hdrIdx+1;i<aoa.length;i++){
        const r=aoa[i];if(!r)continue;
        const ship=cShip>=0?r[cShip]:null;if(!ship)continue;
        const key=String(ship);
        if(!groups[key])groups[key]={dates:[],wh:cSrc>=0?r[cSrc]:null,region:cRegion>=0?String(r[cRegion]||'').toUpperCase():'',accts:{},trucks:{},types:{},pallets:0,cases:0,orders:0,dests:new Set(),outsource:false};
        const g=groups[key];
        const sd=cDate>=0?r[cDate]:null;
        if(sd){const dt=(sd instanceof Date)?sd:new Date(sd);if(!isNaN(dt))g.dates.push(dt.toISOString().slice(0,10));}
        const acct=cAcct>=0?r[cAcct]:null;if(acct)g.accts[acct]=(g.accts[acct]||0)+1;
        const truck=cTruck>=0?r[cTruck]:null;if(truck)g.trucks[truck]=(g.trucks[truck]||0)+1;
        const ty=cType>=0?r[cType]:null;if(ty)g.types[ty]=(g.types[ty]||0)+1;
        g.pallets+=Number(cPallets>=0?r[cPallets]:0)||0;
        g.cases+=Number(cCases>=0?r[cCases]:0)||0;
        g.orders+=1;
        const dest=cDest>=0?r[cDest]:null;if(dest)g.dests.add(String(dest));
        const flag=cFleet>=0?r[cFleet]:null;
        if(flag&&String(flag).toUpperCase()==='OUTSOURCE')g.outsource=true;
      }
      Object.values(groups).forEach(g=>{
        const truckPlate=Object.entries(g.trucks).sort((a,b)=>b[1]-a[1])[0]?.[0]||'—';
        const ttype=Object.entries(g.types).sort((a,b)=>b[1]-a[1])[0]?.[0]||'UNKNOWN';
        const acct=Object.entries(g.accts).sort((a,b)=>b[1]-a[1])[0]?.[0]||'Unspecified';
        let own;
        if(g.outsource)own='T';
        else{const f=PLATE_OWN[normPlate(truckPlate)];own=f?(f==='Dedicated'?'D':'O'):'U';}
        out.push([g.dates.sort()[0]||'',String(g.wh||'UNKNOWN'),g.region||'UNKNOWN',String(acct),String(truckPlate),String(ttype),own,+g.pallets.toFixed(1),Math.round(g.cases),g.orders,g.dests.size||1,'N','T']);
      });
    }
  }
  return out;
}
function refreshAll(){
  // after an upload, data lives in HUBS_ALL/REGIONS_ALL/TRIPS — recompute via the system filter
  sysFilter='all';
  applySystemFilter();
  const badge=document.getElementById('trip-badge');if(badge)badge.textContent=fmtN(TOTAL_TRIPS)+' trips analyzed';
  // reset sub-filters
  ctGlobal='all';ctHubStatus='all';ctRegFilter='all';hubReg='all';hubTblStatus='all';
  fReg='all';fType='all';fStat='all';fBiz='all';fBizGroup='all';fYear='all';opOwn='all';
  renderSystemPills();
  renderCT();renderCtRegionPills();drawCtRegion();drawCtDonut();
  const active=document.querySelector('.tab-panel.active');
  if(active?.id==='tab-hub'){renderHubPills();renderHubTable();drawHubBars();}
  if(active?.id==='tab-convert'){renderConversion();drawConvChart();}
  if(active?.id==='tab-fleet')renderFleetFilters();
  if(active?.id==='tab-exc')renderExceptions();
}

