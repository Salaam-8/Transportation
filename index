  const regions=new Set(d.map(f=>f.region).filter(Boolean)).size;
  const palletCap=d.filter(f=>f.active).reduce((s,f)=>s+(f.pallets||0),0);
  const subTag=isFiltered?'In current filter':'';
  const kp=[
    {lbl:isFiltered?'Vehicles in View':'Total Fleet',val:d.length,sub:isFiltered?`of ${FLEET_DATA.length} total`:'Registered vehicles',icon:'🚛',ac:'var(--brand)'},
    {lbl:'Active',val:active,sub:d.length?`${(active/d.length*100).toFixed(0)}% available`:'—',icon:'✅',ac:'var(--green)'},
    {lbl:'Inactive',val:inact,sub:'Workshop / accident',icon:'🔧',ac:'var(--red)'},
    {lbl:'No Driver',val:noDrv,sub:'Awaiting assignment',icon:'👤',ac:'var(--amber)'},
    {lbl:'Pallet Capacity',val:fmtN(palletCap),sub:isFiltered?'Active in filter':'Active fleet total',icon:'📦',ac:'var(--blue)'},
    {lbl:'Regions',val:regions,sub:isFiltered?'In filter':'Coverage',icon:'📍',ac:'var(--teal)'},
  ];
  document.getElementById('fleet-kpi').innerHTML=kp.map(k=>`<div class="kpi" style="--accent:${k.ac}"><div class="kpi-hdr"><span class="kpi-lbl">${k.lbl}</span><div class="kpi-icon" style="background:${k.ac}1a">${k.icon}</div></div><div class="kpi-val">${k.val}</div><div class="kpi-sub">${k.sub}</div></div>`).join('');
}
function sortFleet(k){if(fSort===k)fDir=fDir==='asc'?'desc':'asc';else{fSort=k;fDir='asc';}renderFleetTable();}
function getFilteredFleet(){
  let d=[...FLEET_DATA];
  if(fReg!=='all')d=d.filter(f=>f.region===fReg);
  if(fType!=='all'){
    if(fType==='Trailer - CS')d=d.filter(f=>f.type==='Trailer - CS');
    else if(fType==='TRAILER')d=d.filter(f=>f.type.includes('TRAILER'));
    else d=d.filter(f=>f.type.toLowerCase().includes(fType.toLowerCase()));
  }
  if(fStat==='Active')d=d.filter(f=>f.status==='Active');
  else if(fStat==='Active - Workshop')d=d.filter(f=>f.status.includes('Workshop'));
  else if(fStat==='Inactive')d=d.filter(f=>!f.active);
  if(fBizGroup!=='all')d=d.filter(f=>bizGroupOf(f.biz||'—')===fBizGroup);
  if(fBiz!=='all')d=d.filter(f=>(f.biz||'—')===fBiz);
  if(fYear!=='all')d=d.filter(f=>String(f.yr)===String(fYear));
  const q=(document.getElementById('fleet-search')?.value||'').toLowerCase();
  if(q)d=d.filter(f=>(f.plate||'').toLowerCase().includes(q)||(f.driver||'').toLowerCase().includes(q)||(f.biz||'').toLowerCase().includes(q));
  return d;
}
function renderFleetTable(){
  let d=getFilteredFleet();
  d.sort((a,b)=>{let va=a[fSort],vb=b[fSort];if(typeof va==='string'){va=va||'';vb=vb||'';return fDir==='asc'?va.localeCompare(vb):vb.localeCompare(va);}return fDir==='asc'?(va||0)-(vb||0):(vb||0)-(va||0);});
  document.getElementById('fleet-count-lbl').textContent=`${d.length} vehicles`;
  document.getElementById('fleet-tbody').innerHTML=d.map(f=>`
    <tr>
      <td class="mono" style="font-size:11px;color:var(--muted)">${f.no}</td>
      <td class="mono" style="font-size:11px;font-weight:600;color:var(--brand)">${esc(f.plate)}</td>
      <td class="mono" style="font-size:11px">${f.yr||'—'}</td>
      <td style="font-size:11px">${esc(f.type)}</td>
      <td style="font-size:11px;color:var(--muted)">${esc(f.brand)}</td>
      <td style="font-size:11px">${esc(f.driver||'—')}</td>
      <td><span class="badge badge-gray" style="font-size:10px">${esc(f.biz)}</span></td>
      <td><span class="badge badge-gray" style="font-size:10px">${esc(f.region)}</span></td>
      <td class="mono" style="text-align:center">${f.pallets||0}</td>
      <td>${mvpiBadge(f.mvpi)}</td>
      <td>${statusBadge(f.status)}</td>
    </tr>`).join('');
}

