const OWN_FULL={O:'Owned',D:'Dedicated',T:'Trip-based',U:'Unknown'};
const POD_FULL={D:'Delivered',P:'Pending',R:'Returned',N:'N/A'};
const SYS_CODE={OTM:'O',TMS:'T'};
const OWN_COLOR={O:'var(--brand)',D:'var(--blue)',T:'var(--amber)',U:'var(--muted)'};
function normPlate(s){return String(s||'').toUpperCase().replace(/[^A-Z0-9]/g,'');}
let PLATE_CAP={},PLATE_OWN={};
function rebuildFleetIndex(){PLATE_CAP={};PLATE_OWN={};FLEET_DATA.forEach(f=>{const k=normPlate(f.plate);PLATE_CAP[k]=f.pallets||0;PLATE_OWN[k]=f.own||'Owned';});}
rebuildFleetIndex();
let sysFilter='all';
let HUBS=[], REGIONS=[], PROVIDERS=[];
function applySystemFilter(){
  // For TMS: regions can have same name as OTM; merge when 'all'
  if(sysFilter==='all'){
    // merge hubs by combining both systems (keep separate rows, they have distinct codes/systems)
    HUBS = HUBS_ALL.slice();
    // merge regions by name across systems
    const rmap={};
    REGIONS_ALL.forEach(r=>{
      if(!rmap[r.region]) rmap[r.region]={region:r.region,tamer:0,outsource:0,total:0};
      rmap[r.region].tamer+=r.tamer; rmap[r.region].outsource+=r.outsource; rmap[r.region].total+=r.total;
    });
    REGIONS = Object.values(rmap).map(r=>({...r,tamer_pct:+(r.tamer/r.total*100).toFixed(1),outsource_pct:+(r.outsource/r.total*100).toFixed(1)})).sort((a,b)=>b.total-a.total);
    // merge providers by name
    const pmap={};
    ['OTM','TMS'].forEach(s=>(PROVIDERS_BY_SYS[s]||[]).forEach(p=>{pmap[p.name]=(pmap[p.name]||0)+p.trips;}));
    PROVIDERS = Object.entries(pmap).map(([name,trips])=>({name,trips})).sort((a,b)=>b.trips-a.trips).slice(0,8);
    TOTAL_TRIPS=7507; TOTAL_TAMER=2878; TOTAL_OUTSOURCE=4629; TAMER_PCT=+(2878/7507*100).toFixed(2);
    AVG_PALLETS=2.27;
  } else {
    HUBS = HUBS_ALL.filter(h=>h.system===sysFilter);
    REGIONS = REGIONS_ALL.filter(r=>r.system===sysFilter).map(r=>({...r})).sort((a,b)=>b.total-a.total);
    PROVIDERS = (PROVIDERS_BY_SYS[sysFilter]||[]).slice();
    const t=TOTALS_BY_SYS[sysFilter];
    TOTAL_TRIPS=t.trips; TOTAL_TAMER=t.tamer; TOTAL_OUTSOURCE=t.outsource; TAMER_PCT=t.tamer_pct; AVG_PALLETS=t.avg_pallets;
  }
}
applySystemFilter();
function setSystem(s){
  sysFilter=s;
  applySystemFilter();
  // reset sub-filters & re-render current tab
  ctGlobal='all';ctHubStatus='all';ctRegFilter='all';hubReg='all';hubTblStatus='all';
  renderSystemPills();
  const tb=document.getElementById('trip-badge');if(tb)tb.textContent=fmtN(TOTAL_TRIPS)+' trips analyzed';
  renderCT();renderCtRegionPills();drawCtRegion();drawCtDonut();
  const active=document.querySelector('.tab-panel.active');
  if(active){const id=active.id;
    if(id==='tab-hub'){renderHubPills();renderHubTable();drawHubBars();}
    if(id==='tab-convert'){renderConversion();drawConvChart();}
    if(id==='tab-exc')renderExceptions();
    // ops merged into CT tab
  }
}
function renderSystemPills(){
  const sys=[['all','🔀 OTM + TMS'],['OTM','OTM'],['TMS','TMS']];
  document.querySelectorAll('.system-pills').forEach(el=>{
    el.innerHTML=sys.map(([v,l])=>`<button class="pill ${sysFilter===v?'active':''}" onclick="setSystem('${v}')">${l}</button>`).join('');
  });
  const lbl=document.getElementById('system-scope-lbl');
  if(lbl){const nm=sysFilter==='all'?'OTM + TMS combined':sysFilter;lbl.textContent=`${nm} · ${fmtN(TOTAL_TRIPS)} trips · ${HUBS.length} hubs`;}
}

// ═══ HELPERS ═══
const fmtN=n=>Math.round(n).toLocaleString();
// Escapes any value before it is inserted into innerHTML. Required because
// hub/fleet/account names etc. can originate from an uploaded spreadsheet —
// without this, a malicious cell value could inject script (XSS).
function esc(v){
  if(v===null||v===undefined)return'';
  return String(v).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}
const pct=(a,b)=>b?Math.round(a/b*100):0;
function svgEl(t,a={}){const e=document.createElementNS('http://www.w3.org/2000/svg',t);Object.entries(a).forEach(([k,v])=>e.setAttribute(k,v));return e;}
function hubColor(p){return p>=60?'#1B7A4A':p>=40?'#C28A0E':'#C0392B'}
function hubBadge(p){if(p>=60)return`<span class="badge badge-green">On target</span>`;if(p>=40)return`<span class="badge badge-amber">Near miss</span>`;return`<span class="badge badge-red">Exception</span>`;}
function statusBadge(s){if(!s||s==='Unknown')return`<span class="badge badge-gray">—</span>`;if(s==='Active')return`<span class="badge badge-green">Active</span>`;if(s.startsWith('Active'))return`<span class="badge badge-amber">${s.replace('Active - ','')}</span>`;return`<span class="badge badge-red">${s.replace('Inactive - ','')}</span>`;}
function mvpiBadge(d){if(!d)return'<span class="badge badge-gray">—</span>';const days=Math.round((new Date(d)-new Date('2026-06-11'))/864e5);if(days<0)return`<span class="badge badge-red">Expired ${Math.abs(days)}d</span>`;if(days<=30)return`<span class="badge badge-amber">${days}d left</span>`;if(days<=90)return`<span class="badge" style="background:#FFF3D4;color:#7A4E00">${days}d left</span>`;return`<span class="badge badge-gray">${d}</span>`;}
function splitBar(p){const tw=Math.round(p),tc=hubColor(p);const grad=p>=60?'linear-gradient(90deg,var(--brand),var(--brand-bright))':p>=40?'linear-gradient(90deg,#A8780C,var(--amber))':'linear-gradient(90deg,#A8311F,var(--red))';return`<div style="display:flex;align-items:center;gap:8px"><div class="split-bar" style="flex:1;background:linear-gradient(90deg,rgba(193,59,44,.14),rgba(193,59,44,.06))"><div style="width:${tw}%;background:${grad};transition:width 1s cubic-bezier(.22,1,.36,1);box-shadow:1px 0 3px rgba(11,31,22,.12)"></div></div><span class="mono" style="font-size:11px;font-weight:700;color:${tc};min-width:38px">${p}%</span></div>`;}

