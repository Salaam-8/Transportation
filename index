function drawConvChart(){
  const svg=document.getElementById('conv-svg');if(!svg)return;
  const W=svg.parentElement.offsetWidth||400,H=150;svg.setAttribute('viewBox',`0 0 ${W} ${H}`);svg.innerHTML='';
  const data=REGIONS.map(r=>({region:r.region,conv:Math.max(0,Math.round(r.total*0.6)-r.tamer)}));
  const maxV=Math.max(...data.map(d=>d.conv),1),pad={l:36,r:12,t:18,b:30},cW=W-pad.l-pad.r,cH=H-pad.t-pad.b,step=cW/data.length,bW=Math.min(52,step*.52);
  const tip=document.getElementById('conv-tip');
  const defs=svgEl('defs');
  const tg=svgEl('linearGradient',{id:'convGrad',x1:'0%',y1:'0%',x2:'0%',y2:'100%'});
  tg.appendChild(svgEl('stop',{offset:'0%','stop-color':'#16A5A5'}));
  tg.appendChild(svgEl('stop',{offset:'100%','stop-color':'#0D8585'}));defs.appendChild(tg);
  const csh=svgEl('filter',{id:'convSh',x:'-30%',y:'-10%',width:'160%',height:'130%'});
  csh.appendChild(svgEl('feDropShadow',{dx:'0',dy:'2','stdDeviation':'2','flood-color':'#085C5C','flood-opacity':'.2'}));defs.appendChild(csh);
  svg.appendChild(defs);
  for(let i=0;i<=3;i++){const y=pad.t+cH*(1-i/3);svg.appendChild(svgEl('line',{x1:pad.l,y1:y,x2:W-pad.r,y2:y,stroke:'#EAF0EC','stroke-width':1}));const l=svgEl('text',{x:pad.l-6,y:y+4,fill:'#93A89C','font-size':9,'text-anchor':'end','font-family':'Inter','font-weight':'600'});l.textContent=fmtN(maxV*i/3);svg.appendChild(l);}
  data.forEach((d,i)=>{const x=pad.l+i*step+step/2,bH=(d.conv/maxV)*cH,bx=x-bW/2,by=pad.t+cH-bH;
    svg.appendChild(svgEl('rect',{x:bx,y:pad.t,width:bW,height:cH,fill:'rgba(13,133,133,.06)',rx:7,stroke:'rgba(13,133,133,.13)','stroke-width':1}));
    const bar=svgEl('rect',{x:bx,y:by,width:bW,height:bH,fill:'url(#convGrad)',rx:7,style:'cursor:pointer',filter:'url(#convSh)'});
    bar.addEventListener('mouseenter',()=>{tip.style.display='block';tip.innerHTML=`<b>${d.region}</b><br>Convert ${fmtN(d.conv)} trips to Tamer`;});
    bar.addEventListener('mousemove',e=>{const r=svg.parentElement.getBoundingClientRect();tip.style.left=(e.clientX-r.left+12)+'px';tip.style.top=(e.clientY-r.top-38)+'px';});
    bar.addEventListener('mouseleave',()=>tip.style.display='none');svg.appendChild(bar);
    const vl=svgEl('text',{x,y:by-6,fill:'#0D8585','font-size':11,'text-anchor':'middle','font-weight':'800','font-family':'Plus Jakarta Sans'});vl.textContent='+'+fmtN(d.conv);svg.appendChild(vl);
    const ll=svgEl('text',{x,y:pad.t+cH+16,fill:'#2E443A','font-size':10.5,'text-anchor':'middle','font-family':'Inter','font-weight':'700'});ll.textContent=d.region;svg.appendChild(ll);
  });
}

